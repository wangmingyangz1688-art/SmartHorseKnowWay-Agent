
# LLM配置 
# 模型名称
LLM_MODEL_ID='LongCat-2.0-Preview'

# API密钥
LLM_API_KEY=your-api-key-here

# 服务地址
LLM_BASE_URL='https://api.longcat.chat/openai/v1'

# 超时时间（可选，默认600秒）
LLM_TIMEOUT=600

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS配置
CORS_ORIGINS=http://localhost:8888,http://localhost:3000

# 日志级别
LOG_LEVEL=INFO

# 高德地图API配置
AMAP_API_KEY=your_amap_api_key_here

# 2026-06-04: Neo4j图谱记忆配置（可选）
# Neo4j Desktop 启动实例后，Connection URI 通常是 neo4j://127.0.0.1:7687
NEO4J_ENABLED=false
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j
